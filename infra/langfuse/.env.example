# Langfuse local dev — copy to .env (auto-created by `make up` if missing)
# Local-only secrets; do not use in production.

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-run-openssl-rand-base64-32

# Optional: replace defaults for stronger local security
# ENCRYPTION_KEY=<openssl rand -hex 32>
# SALT=<openssl rand -base64 16>
# REDIS_AUTH=<random>
# MINIO_ROOT_PASSWORD=<random>
# CLICKHOUSE_PASSWORD=<random>
# POSTGRES_PASSWORD=<random>

# Pre-seeded project — copy keys to repo root .env
LANGFUSE_INIT_ORG_NAME=LLMStart Local
LANGFUSE_INIT_PROJECT_NAME=llmstart-agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-llmstart-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-llmstart-local
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=langfuse-local-dev
