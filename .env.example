# LLMStart Agent — environment variables template
# Copy to .env and fill in values. Never commit .env to git.

# --- Backend (required) ---
OPENAI_API_KEY=your-api-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
BACKEND_API_KEY=change-me-shared-secret

# --- Backend (optional) ---
# Azure OpenAI-compatible proxy (omit OPENAI_API_BASE for api.openai.com)
OPENAI_API_BASE=https://ai-proxy...
OPENAI_API_VERSION=2024-02-01
OPENAI_MODEL=claude-sonnet-4@20250514
OPENAI_EMBEDDING_MODEL=text-embedding-3-small-1
OPENAI_TIMEOUT_SEC=60
# Langfuse Cloud (default). For self-hosted: LANGFUSE_HOST=http://localhost:3001 + make up-langfuse
LANGFUSE_HOST=https://cloud.langfuse.com
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# --- Bot (required when running bot) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Username без @ — для deep link в виджете. Если не задан, frontend попробует getMe по токену.
TELEGRAM_BOT_USERNAME=your_bot_username

# --- Bot / Frontend (optional) ---
BACKEND_URL=http://localhost:8000

# --- Frontend (server-side only; do NOT use NEXT_PUBLIC_ for secrets) ---
# BACKEND_API_KEY is shared with backend/bot (see above)
# TELEGRAM_BOT_USERNAME is used for deep link generation in the widget

# --- MCP (Cursor — .cursor/mcp.json) ---
# Context7: get a free key at https://context7.com/dashboard
# CONTEXT7_API_KEY=ctx7sk-your-key
# Langfuse MCP uses LANGFUSE_HOST + LANGFUSE_PUBLIC_KEY + LANGFUSE_SECRET_KEY (see above)
